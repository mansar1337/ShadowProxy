#!/bin/ash

PODKOP_LIB="/usr/lib/podkop"
[ -r "$PODKOP_LIB/helpers.sh" ] && . "$PODKOP_LIB/helpers.sh"

NODES_DIR="/etc/shadowproxy"
NODES_JSON="$NODES_DIR/nodes.json"
CONFIG_JSON="$NODES_DIR/config.json"

log_msg() {
    local message="$1"
    local level="${2:-info}"
    logger -t "shadowproxy" "[$level] $message"
}

usage() {
    cat <<USAGE
Usage: $0 --url <subscription_url> [--base64] [--ua] [--probe-only]
USAGE
}

is_valid_port() {
    local port="$1"
    [ -n "$port" ] && [ "$port" -ge 1 ] 2>/dev/null && [ "$port" -le 65535 ] 2>/dev/null
}

normalize_transport() {
    local transport="$1"
    case "$transport" in
    tcp|udp|grpc|ws|http|httpupgrade|xhttp)
        if [ "$transport" = "httpupgrade" ] || [ "$transport" = "xhttp" ]; then
            echo "http"
        else
            echo "$transport"
        fi
        ;;
    "")
        echo "tcp"
        ;;
    *)
        return 1
        ;;
    esac
}

normalize_security() {
    local security="$1"
    case "$security" in
    tls|none|reality)
        echo "$security"
        ;;
    "")
        echo "none"
        ;;
    *)
        echo "none"
        ;;
    esac
}

normalize_bool() {
    local value="$1"
    case "$value" in
    1|true|TRUE|True)
        echo "true"
        ;;
    0|false|FALSE|False|"")
        echo "false"
        ;;
    *)
        return 1
        ;;
    esac
}

decode_base64_compat() {
    local raw="$1"
    local normalized pad_len

    normalized=$(printf '%s' "$raw" | tr '_-' '/+')
    pad_len=$(( ${#normalized} % 4 ))
    if [ "$pad_len" -eq 2 ]; then
        normalized="${normalized}=="
    elif [ "$pad_len" -eq 3 ]; then
        normalized="${normalized}="
    elif [ "$pad_len" -eq 1 ]; then
        return 1
    fi

    printf '%s' "$normalized" | base64 -d 2>/dev/null
}

node_id_from_uri() {
    local raw_uri="$1"
    printf '%s' "$raw_uri" | md5sum | awk '{print $1}'
}

decode_node_name() {
    local raw_uri="$1"
    local fragment
    fragment="${raw_uri#*#}"
    if [ "$fragment" = "$raw_uri" ]; then
        echo ""
        return 0
    fi

    if command -v url_decode >/dev/null 2>&1; then
        url_decode "$fragment"
    else
        printf '%b' "$(printf '%s' "$fragment" | sed 's/+/ /g; s/%/\\x/g')" 2>/dev/null
    fi
}

append_node() {
    local nodes_json="$1"
    local node_json="$2"
    printf '%s' "$nodes_json" | jq --argjson node "$node_json" '. + [$node]'
}

build_node_json() {
    local id="$1"
    local protocol="$2"
    local name="$3"
    local server="$4"
    local port="$5"
    local security="$6"
    local insecure="$7"
    local transport="$8"
    local uuid="$9"
    local password="${10}"
    local raw_uri="${11}"
    local sni="${12}"
    local alpn="${13}"
    local obfs="${14}"
    local padding="${15}"
    local hop_interval="${16}"

    jq -cn \
        --arg id "$id" \
        --arg protocol "$protocol" \
        --arg name "$name" \
        --arg server "$server" \
        --argjson port "$port" \
        --arg security "$security" \
        --argjson insecure "$insecure" \
        --arg transport "$transport" \
        --arg uuid "$uuid" \
        --arg password "$password" \
        --arg raw_uri "$raw_uri" \
        --arg sni "$sni" \
        --arg alpn "$alpn" \
        --arg obfs "$obfs" \
        --arg padding "$padding" \
        --arg hop_interval "$hop_interval" \
        '{
            id: $id,
            protocol: $protocol,
            name: $name,
            server: $server,
            port: $port,
            security: $security,
            insecure: $insecure,
            transport: $transport,
            uuid: $uuid,
            password: $password,
            raw_uri: $raw_uri
        }
        + (if $sni != "" then {sni: $sni} else {} end)
        + (if $alpn != "" then {alpn: $alpn} else {} end)
        + (if $obfs != "" then {obfs: $obfs} else {} end)
        + (if $padding != "" then {padding: $padding} else {} end)
        + (if $hop_interval != "" then {"hop-interval": $hop_interval} else {} end)'
}

parse_vless_uri() {
    local uri="$1"
    local stripped auth_host query host port uuid
    local security insecure_raw insecure transport name node_id sni alpn

    stripped="${uri#vless://}"
    stripped="${stripped%%#*}"
    auth_host="${stripped%%\?*}"
    query=""
    [ "$stripped" != "$auth_host" ] && query="${stripped#*\?}"

    uuid="${auth_host%@*}"
    host="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\1/p')"
    port="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\2/p')"

    if [ -z "$uuid" ] || [ -z "$host" ] || ! is_valid_port "$port"; then
        log_msg "Invalid vless node: missing uuid/host/port" "error"
        return 1
    fi

    security="$(normalize_security "$(printf '%s' "$query" | sed -n 's/.*[?&]security=\([^&]*\).*/\1/p')")"
    insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]allowInsecure=\([^&]*\).*/\1/p')"
    [ -z "$insecure_raw" ] && insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]insecure=\([^&]*\).*/\1/p')"
    insecure="$(normalize_bool "$insecure_raw" 2>/dev/null || true)"
    if [ -z "$insecure" ]; then
        log_msg "Invalid allowInsecure/insecure value '$insecure_raw' in vless URI" "error"
        insecure="false"
    fi

    transport="$(printf '%s' "$query" | sed -n 's/.*[?&]type=\([^&]*\).*/\1/p')"
    transport="$(normalize_transport "$transport" 2>/dev/null || true)"
    [ -z "$transport" ] && transport="tcp"

    sni="$(printf '%s' "$query" | sed -n 's/.*[?&]sni=\([^&]*\).*/\1/p')"
    alpn="$(printf '%s' "$query" | sed -n 's/.*[?&]alpn=\([^&]*\).*/\1/p')"

    name="$(decode_node_name "$uri")"
    [ -z "$name" ] && name="vless-${host}:${port}"
    node_id="$(node_id_from_uri "$uri")"

    build_node_json "$node_id" "vless" "$name" "$host" "$port" "$security" "$insecure" "$transport" "$uuid" "" "$uri" "$sni" "$alpn" "" "" ""
}

parse_hy2_uri() {
    local uri="$1"
    local stripped scheme auth_host query host port password
    local insecure_raw insecure transport name node_id sni alpn obfs hop_interval

    scheme="hysteria2"
    stripped="$uri"
    case "$uri" in
    hy2://*)
        scheme="hy2"
        stripped="${uri#hy2://}"
        ;;
    hysteria2://*)
        stripped="${uri#hysteria2://}"
        ;;
    *)
        return 1
        ;;
    esac

    stripped="${stripped%%#*}"
    auth_host="${stripped%%\?*}"
    query=""
    [ "$stripped" != "$auth_host" ] && query="${stripped#*\?}"

    password="${auth_host%@*}"
    host="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\1/p')"
    port="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\2/p')"
    sni="$(printf '%s' "$query" | sed -n 's/.*[?&]sni=\([^&]*\).*/\1/p')"
    alpn="$(printf '%s' "$query" | sed -n 's/.*[?&]alpn=\([^&]*\).*/\1/p')"
    transport="$(printf '%s' "$query" | sed -n 's/.*[?&]type=\([^&]*\).*/\1/p')"

    if [ -z "$password" ] || [ -z "$host" ] || ! is_valid_port "$port" || [ -z "$sni" ] || [ -z "$alpn" ] || [ -z "$transport" ]; then
        log_msg "Invalid ${scheme} node: required fields password/host/port/sni/alpn/type are missing" "error"
        return 1
    fi

    transport="$(normalize_transport "$transport" 2>/dev/null || true)"
    if [ -z "$transport" ]; then
        log_msg "Invalid ${scheme} node transport" "error"
        return 1
    fi

    insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]allowInsecure=\([^&]*\).*/\1/p')"
    [ -z "$insecure_raw" ] && insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]insecure=\([^&]*\).*/\1/p')"
    insecure="$(normalize_bool "$insecure_raw" 2>/dev/null || true)"
    if [ -z "$insecure" ]; then
        log_msg "Invalid allowInsecure/insecure value '$insecure_raw' in ${scheme} URI" "error"
        insecure="false"
    fi

    obfs="$(printf '%s' "$query" | sed -n 's/.*[?&]obfs=\([^&]*\).*/\1/p')"
    hop_interval="$(printf '%s' "$query" | sed -n 's/.*[?&]hop-interval=\([^&]*\).*/\1/p')"

    name="$(decode_node_name "$uri")"
    [ -z "$name" ] && name="hy2-${host}:${port}"
    node_id="$(node_id_from_uri "$uri")"

    build_node_json "$node_id" "hy2" "$name" "$host" "$port" "tls" "$insecure" "$transport" "" "$password" "$uri" "$sni" "$alpn" "$obfs" "" "$hop_interval"
}

parse_trojan_uri() {
    local uri="$1"
    local stripped auth_host query host port password
    local insecure_raw insecure transport name node_id sni alpn security

    stripped="${uri#trojan://}"
    stripped="${stripped%%#*}"
    auth_host="${stripped%%\?*}"
    query=""
    [ "$stripped" != "$auth_host" ] && query="${stripped#*\?}"

    password="${auth_host%@*}"
    host="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\1/p')"
    port="$(printf '%s' "$auth_host" | sed -n 's/^[^@]*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\2/p')"
    sni="$(printf '%s' "$query" | sed -n 's/.*[?&]sni=\([^&]*\).*/\1/p')"
    alpn="$(printf '%s' "$query" | sed -n 's/.*[?&]alpn=\([^&]*\).*/\1/p')"
    transport="$(printf '%s' "$query" | sed -n 's/.*[?&]type=\([^&]*\).*/\1/p')"

    if [ -z "$password" ] || [ -z "$host" ] || ! is_valid_port "$port" || [ -z "$sni" ] || [ -z "$alpn" ] || [ -z "$transport" ]; then
        log_msg "Invalid trojan node: required fields password/host/port/sni/alpn/type are missing" "error"
        return 1
    fi

    transport="$(normalize_transport "$transport" 2>/dev/null || true)"
    if [ -z "$transport" ]; then
        log_msg "Invalid trojan node transport" "error"
        return 1
    fi

    security="$(normalize_security "$(printf '%s' "$query" | sed -n 's/.*[?&]security=\([^&]*\).*/\1/p')")"
    [ "$security" = "none" ] && security="tls"

    insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]allowInsecure=\([^&]*\).*/\1/p')"
    [ -z "$insecure_raw" ] && insecure_raw="$(printf '%s' "$query" | sed -n 's/.*[?&]insecure=\([^&]*\).*/\1/p')"
    insecure="$(normalize_bool "$insecure_raw" 2>/dev/null || true)"
    if [ -z "$insecure" ]; then
        log_msg "Invalid allowInsecure/insecure value '$insecure_raw' in trojan URI" "error"
        insecure="false"
    fi

    name="$(decode_node_name "$uri")"
    [ -z "$name" ] && name="trojan-${host}:${port}"
    node_id="$(node_id_from_uri "$uri")"

    build_node_json "$node_id" "trojan" "$name" "$host" "$port" "$security" "$insecure" "$transport" "" "$password" "$uri" "$sni" "$alpn" "" "" ""
}

parse_ss_uri() {
    local uri="$1"
    local stripped auth_host query credentials host port
    local method password transport name node_id security obfs padding

    stripped="${uri#ss://}"
    stripped="${stripped%%#*}"
    auth_host="${stripped%%\?*}"
    query=""
    [ "$stripped" != "$auth_host" ] && query="${stripped#*\?}"

    credentials="${auth_host%@*}"
    host="$(printf '%s' "$auth_host" | sed -n 's/^.*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\1/p')"
    port="$(printf '%s' "$auth_host" | sed -n 's/^.*@\([^:/?#]*\):\([0-9][0-9]*\).*$/\2/p')"

    if [ "$credentials" = "$auth_host" ]; then
        log_msg "Invalid ss node: credentials block is missing" "error"
        return 1
    fi

    if ! printf '%s' "$credentials" | grep -q ':'; then
        credentials="$(decode_base64_compat "$credentials" 2>/dev/null || true)"
    fi

    method="${credentials%%:*}"
    password="${credentials#*:}"
    transport="$(printf '%s' "$query" | sed -n 's/.*[?&]type=\([^&]*\).*/\1/p')"

    if [ -z "$method" ] || [ -z "$password" ] || [ -z "$host" ] || ! is_valid_port "$port" || [ -z "$transport" ]; then
        log_msg "Invalid ss node: required fields method/password/host/port/type are missing" "error"
        return 1
    fi

    transport="$(normalize_transport "$transport" 2>/dev/null || true)"
    if [ -z "$transport" ]; then
        log_msg "Invalid ss node transport" "error"
        return 1
    fi

    security="$(normalize_security "$(printf '%s' "$query" | sed -n 's/.*[?&]security=\([^&]*\).*/\1/p')")"
    obfs="$(printf '%s' "$query" | sed -n 's/.*[?&]obfs=\([^&]*\).*/\1/p')"
    padding="$(printf '%s' "$query" | sed -n 's/.*[?&]padding=\([^&]*\).*/\1/p')"

    name="$(decode_node_name "$uri")"
    [ -z "$name" ] && name="ss-${host}:${port}"
    node_id="$(node_id_from_uri "$uri")"

    build_node_json "$node_id" "ss" "$name" "$host" "$port" "$security" "false" "$transport" "" "$password" "$uri" "" "" "$obfs" "$padding" ""
}

parse_vmess_uri() {
    local uri="$1"
    local payload decoded node_id name host port uuid security insecure transport alpn sni

    payload="${uri#vmess://}"
    decoded="$(decode_base64_compat "$payload" 2>/dev/null || true)"
    if [ -z "$decoded" ] || ! printf '%s' "$decoded" | jq -e . >/dev/null 2>&1; then
        log_msg "Invalid vmess node: cannot decode vmess payload" "error"
        return 1
    fi

    host="$(printf '%s' "$decoded" | jq -r '.add // ""')"
    port="$(printf '%s' "$decoded" | jq -r '.port // ""')"
    uuid="$(printf '%s' "$decoded" | jq -r '.id // ""')"
    security="$(printf '%s' "$decoded" | jq -r '.tls // .security // "none"')"
    insecure="$(printf '%s' "$decoded" | jq -r '.allowInsecure // .insecure // 0')"
    transport="$(printf '%s' "$decoded" | jq -r '.net // "tcp"')"
    name="$(printf '%s' "$decoded" | jq -r '.ps // ""')"
    alpn="$(printf '%s' "$decoded" | jq -r '.alpn // ""')"
    sni="$(printf '%s' "$decoded" | jq -r '.sni // .host // ""')"

    if [ -z "$host" ] || ! is_valid_port "$port" || [ -z "$uuid" ]; then
        log_msg "Invalid vmess node: missing host/port/uuid" "error"
        return 1
    fi

    transport="$(normalize_transport "$transport" 2>/dev/null || true)"
    [ -z "$transport" ] && transport="tcp"
    security="$(normalize_security "$security")"

    insecure="$(normalize_bool "$insecure" 2>/dev/null || true)"
    [ -z "$insecure" ] && insecure="false"

    [ -z "$name" ] && name="vmess-${host}:${port}"
    node_id="$(node_id_from_uri "$uri")"

    build_node_json "$node_id" "vmess" "$name" "$host" "$port" "$security" "$insecure" "$transport" "$uuid" "" "$uri" "$sni" "$alpn" "" "" ""
}

now_ms() {
    local now
    now=$(date +%s%3N 2>/dev/null)
    case "$now" in
        *N*) echo $(( $(date +%s) * 1000 )) ;;
        *) echo "$now" ;;
    esac
}

run_with_timeout() {
    local timeout_sec="$1"
    shift

    if command -v timeout >/dev/null 2>&1; then
        timeout "$timeout_sec" "$@"
        return $?
    fi

    "$@" &
    local cmd_pid=$!
    (
        sleep "$timeout_sec"
        kill -TERM "$cmd_pid" >/dev/null 2>&1 || true
        sleep 1
        kill -KILL "$cmd_pid" >/dev/null 2>&1 || true
    ) &
    local watchdog_pid=$!

    wait "$cmd_pid"
    local cmd_rc=$?
    kill -TERM "$watchdog_pid" >/dev/null 2>&1 || true
    wait "$watchdog_pid" 2>/dev/null || true
    return "$cmd_rc"
}

probe_node() {
    local id="$1"
    local server="$2"
    local port="$3"
    local security="$4"
    local sni="$5"
    local result_file="$6"

    local start end rtt
    start=$(now_ms)

    if [ "$security" = "tls" ] || [ "$security" = "reality" ]; then
        if [ -z "$sni" ]; then
            sni="$server"
        fi

        run_with_timeout 3 openssl s_client -connect "${server}:${port}" -servername "$sni" -brief </dev/null >/dev/null 2>&1 || return 1
    else
        if command -v nc >/dev/null 2>&1; then
            run_with_timeout 3 nc -z -w 3 "$server" "$port" >/dev/null 2>&1 || return 1
        else
            return 1
        fi
    fi

    end=$(now_ms)
    rtt=$(( end - start ))
    [ "$rtt" -lt 0 ] && rtt=0
    echo "$id $rtt" >> "$result_file"
}

pick_best_node() {
    local nodes_file="$1"
    local result_file="$2"
    local nodes_tmp

    : > "$result_file"
    nodes_tmp=$(mktemp)
    jq -c '.[]' "$nodes_file" > "$nodes_tmp"

    while IFS= read -r node; do
        local id server port security sni
        id=$(printf '%s' "$node" | jq -r '.id')
        server=$(printf '%s' "$node" | jq -r '.server')
        port=$(printf '%s' "$node" | jq -r '.port')
        security=$(printf '%s' "$node" | jq -r '.security')
        sni=$(printf '%s' "$node" | jq -r '.sni // empty')

        probe_node "$id" "$server" "$port" "$security" "$sni" "$result_file" &
    done < "$nodes_tmp"

    wait
    rm -f "$nodes_tmp"

    if [ ! -s "$result_file" ]; then
        return 1
    fi

    sort -k2n "$result_file" | head -n1 | awk '{print $1}'
}

convert_subscription_to_nodes() {
    local input_file="$1"
    local nodes_file="$2"
    local links_file
    local nodes_json='[]'
    local uri node_json parsed=0 skipped=0

    links_file=$(mktemp)
    grep -Eo '(vless|hysteria2|hy2|trojan|vmess|ss)://[^[:space:]]+' "$input_file" > "$links_file"

    while IFS= read -r uri; do
        [ -z "$uri" ] && continue
        node_json=""

        case "$uri" in
        vless://*) node_json="$(parse_vless_uri "$uri" || true)" ;;
        hysteria2://*|hy2://*) node_json="$(parse_hy2_uri "$uri" || true)" ;;
        trojan://*) node_json="$(parse_trojan_uri "$uri" || true)" ;;
        vmess://*) node_json="$(parse_vmess_uri "$uri" || true)" ;;
        ss://*) node_json="$(parse_ss_uri "$uri" || true)" ;;
        esac

        if [ -z "$node_json" ] || ! printf '%s' "$node_json" | jq -e . >/dev/null 2>&1; then
            skipped=$((skipped + 1))
            continue
        fi

        nodes_json="$(append_node "$nodes_json" "$node_json")"
        parsed=$((parsed + 1))
    done < "$links_file"

    rm -f "$links_file"

    printf '%s\n' "$nodes_json" | jq . > "$nodes_file"

    if [ "$parsed" -eq 0 ]; then
        log_msg "No valid nodes parsed from subscription (skipped: $skipped)" "error"
        return 1
    fi

    log_msg "Parsed nodes: $parsed, skipped: $skipped"
    return 0
}

main() {
    local url=""
    local decode_base64="0"
    local custom_ua="0"
    local probe_only="0"

    while [ $# -gt 0 ]; do
        case "$1" in
        --url)
            url="$2"
            shift 2
            ;;
        --base64)
            decode_base64="1"
            shift
            ;;
        --ua)
            custom_ua="1"
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --probe-only)
            probe_only="1"
            shift
            ;;
        *)
            usage
            exit 1
            ;;
        esac
    done

    if [ "$probe_only" != "1" ] && [ -z "$url" ]; then
        log_msg "Subscription URL is required" "error"
        usage
        exit 1
    fi

    mkdir -p "$NODES_DIR"

    local raw_file processed_file probe_result active_node previous_active headers_file
    raw_file=""
    processed_file=""
    probe_result=$(mktemp)
    headers_file=""

    if [ "$probe_only" != "1" ]; then
        raw_file=$(mktemp)
        processed_file=$(mktemp)
        headers_file=$(mktemp)
    fi

    local curl_args curl_supports_compressed
    curl_args="--fail --silent --show-error --location --max-time 15 --connect-timeout 15 --retry 2 --retry-delay 1 --retry-all-errors"
    curl_supports_compressed="0"

    if [ "$probe_only" != "1" ]; then
        if curl --help all 2>/dev/null | grep -q -- '--compressed' \
            && curl --compressed --silent --show-error --output /dev/null file:///dev/null >/dev/null 2>&1; then
            curl_supports_compressed="1"
            curl_args="$curl_args --compressed"
        fi

        if [ "$custom_ua" = "1" ]; then
            curl $curl_args \
                -H 'User-Agent: ShadowProxy/latest/OpenWRT/17764321936841767581' \
                -H 'x-device-locale: ru' \
                -H 'x-hwid: 4781f93918j' \
                -H 'x-device-os: Linux' \
                -H 'x-ver-os: 13' \
                -H 'x-device-model: ShadowProxy-OpenWRT' \
                -H 'accept-encoding: gzip' \
                -D "$headers_file" \
                -o "$raw_file" "$url"
        else
            curl $curl_args -D "$headers_file" -o "$raw_file" "$url"
        fi

        if [ $? -ne 0 ] || [ ! -s "$raw_file" ]; then
            log_msg "Failed to fetch subscription URL" "error"
            rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
            exit 1
        fi

        if [ "$curl_supports_compressed" = "0" ] && grep -qi '^content-encoding:[[:space:]]*gzip' "$headers_file"; then
            if command -v gzip >/dev/null 2>&1; then
                if ! gzip -dc "$raw_file" > "$raw_file.tmp" 2>/dev/null; then
                    log_msg "Failed to decode gzip response body" "error"
                    rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file" "$raw_file.tmp"
                    exit 1
                fi
            elif command -v gunzip >/dev/null 2>&1; then
                if ! gunzip -c "$raw_file" > "$raw_file.tmp" 2>/dev/null; then
                    log_msg "Failed to decode gzip response body" "error"
                    rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file" "$raw_file.tmp"
                    exit 1
                fi
            else
                log_msg "Gzip response received, but no gzip/gunzip tool is available" "error"
                rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
                exit 1
            fi

            mv "$raw_file.tmp" "$raw_file"
        fi

        if [ "$decode_base64" = "1" ]; then
            if ! tr -d '\r\n\t ' < "$raw_file" | base64 -d > "$processed_file" 2>/dev/null; then
                log_msg "Failed to decode base64 subscription payload" "error"
                rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
                exit 1
            fi
        else
            cp "$raw_file" "$processed_file"
        fi

        if ! convert_subscription_to_nodes "$processed_file" "$NODES_JSON"; then
            rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
            exit 1
        fi
    elif [ ! -s "$NODES_JSON" ]; then
        log_msg "Nodes list is missing or empty, probe-only mode cannot continue" "error"
        rm -f "$probe_result"
        exit 1
    fi

    previous_active=""
    if [ -f "$CONFIG_JSON" ]; then
        previous_active="$(jq -r '.active_node // empty' "$CONFIG_JSON" 2>/dev/null)"
    fi

    active_node="$(pick_best_node "$NODES_JSON" "$probe_result" 2>/dev/null || true)"
    if [ -z "$active_node" ]; then
        log_msg "All nodes are unavailable, preserving previous active node: ${previous_active:-none}" "error"
        rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
        exit 1
    fi

    if [ -f "$CONFIG_JSON" ] && jq -e . "$CONFIG_JSON" >/dev/null 2>&1; then
        jq --arg active_node "$active_node" '.active_node = $active_node' "$CONFIG_JSON" > "$CONFIG_JSON.tmp" && mv "$CONFIG_JSON.tmp" "$CONFIG_JSON"
    else
        jq -n --arg active_node "$active_node" '{active_node: $active_node}' > "$CONFIG_JSON"
    fi

    log_msg "Selected active node: $active_node"

    rm -f "$raw_file" "$processed_file" "$probe_result" "$headers_file"
    exit 0
}

main "$@"
